# Resend API key — get one at https://resend.com/api-keys
# Required for the registration form to send emails. Without it, the
# /api/register route returns a clear error and no emails are sent.
RESEND_API_KEY=

# Optional overrides (defaults are set in app/api/register/route.ts):

# Where registration submissions are emailed to.
# REGISTRATION_TO_EMAIL=limszekee702@gmail.com

# The "from" address emails are sent from. Must be on a domain you've
# verified with Resend, or leave unset to use Resend's shared test sender
# (onboarding@resend.dev) during development.
# REGISTRATION_FROM_EMAIL="ROBO ARENA 2026 <onboarding@resend.dev>"
